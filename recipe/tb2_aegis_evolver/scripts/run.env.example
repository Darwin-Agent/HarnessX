# TB2 AEGIS evolution — environment template.
# Copy this file to run.env and fill in your values.
# Lines starting with # are comments and are ignored.

# ── Initial harness config ────────────────────────────────────────────────────
AEGIS_CONFIG=benchmarks/terminal_bench_2/harness_baseline_config.yaml

# ── Output directory (auto-generated timestamp name if unset) ─────────────────
# AEGIS_RUN_DIR=.benchmarks/aegis-runs/my-run

# ── Warm-start: reuse existing trials for round 1 (skips first eval) ─────────
# AEGIS_R0_TRIALS=.benchmarks/tb2/my-existing-trials

# ── Task list (defaults to 16-task sample) ────────────────────────────────────
# AEGIS_TASKS=recipe/tb2_hx_evolver/tasks_sample16_seed42_lt15m.json

# ── Eval settings ─────────────────────────────────────────────────────────────
AEGIS_NUM_ROUNDS=5
AEGIS_CONCURRENT=16
AEGIS_K=3

# ── AEGIS model settings ──────────────────────────────────────────────────────
# Meta model: used by Planner and Critic (Opus recommended)
AEGIS_META_MODEL=anthropic/claude-opus-4-6
# Replay gate model: the benchmark model used to replay candidate configs
AEGIS_REPLAY_MODEL=anthropic/claude-sonnet-4-6

# ── AEGIS evolution settings ──────────────────────────────────────────────────
AEGIS_NUM_EVOLVERS=4
AEGIS_BUDGET_USD=20.0
AEGIS_MAX_CONCURRENCY=4

# ── Provider credentials ──────────────────────────────────────────────────────
ANTHROPIC_BASE_URL=http://your-proxy-host/anthropic
ANTHROPIC_API_KEY=sk-your-key-here

# Optional: override base URL / API key for AEGIS meta calls only
# AEGIS_BASE_URL=http://your-proxy-host/anthropic
# AEGIS_API_KEY=sk-your-key-here
# AEGIS_PROVIDER_ID=your-provider-id

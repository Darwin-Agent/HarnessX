# TB2 Harness Evolution — configuration template
# Copy to evol.env (or any name), fill in, then:
#   bash recipe/tb2_hx_evolver/scripts/run_full_evol.sh --env /path/to/evol.env

# ── Evol agent API (DigestAgent / EvolveAgent) ───────────────────────────────
# EVOL_BASE_URL / EVOL_API_KEY 统一给两个 agent 用
# anthropic/ 前缀模型优先用 EVOL_BASE_URL，fallback 到 ANTHROPIC_BASE_URL
EVOL_BASE_URL=http://model.mify.ai.srv/anthropic
EVOL_API_KEY=sk-xxxxx
# EVOL_PROVIDER_ID=                    # 可选，填写后附加 X-Model-Provider-Id 请求头
# ANTHROPIC_BASE_URL=                  # anthropic/ 模型的 fallback base_url

# ── Task-agent model under test (passed to eval_local_docker.sh) ─────────────
TB2_MODEL=qwen3.5-27b
TB2_API_BASE=http://your-inference-endpoint/v1
TB2_API_KEY=sk-xxxxx

# ── Evol agent models ─────────────────────────────────────────────────────────
# anthropic/ 前缀走 AnthropicProvider；其他走 OpenAIProvider
EVOL_DIGEST_MODEL=anthropic/claude-haiku-4-5-20251001
EVOL_EVOLVE_MODEL=anthropic/claude-sonnet-4-6

# ── Task set ──────────────────────────────────────────────────────────────────
# 16-task sample (timeout < 15 min, seed=42)
EVOL_TASKS=recipe/tb2_hx_evolver/tasks_sample16_seed42_lt15m.json

# ── Baseline harness config ───────────────────────────────────────────────────
EVOL_CONFIG=benchmarks/terminal_bench_2/harness_baseline_config.yaml

# ── Output directory (leave blank for auto .benchmarks/evolve-runs/evolve-<ts>)
# EVOL_RUN_DIR=.benchmarks/evolve-runs/my-run

# ── Round-0 warm-start: skip first eval and reuse existing trials ─────────────
# EVOL_R0_TRIALS=.benchmarks/tb2/qwen3.5-27b-local-k5-0511

# ── Loop hyperparams ─────────────────────────────────────────────────────────
EVOL_NUM_ROUNDS=5
EVOL_CONCURRENT=4
EVOL_K=3

# ── Agent step budgets ────────────────────────────────────────────────────────
EVOL_DIGEST_MAX_STEPS=200
EVOL_EVOLVE_MAX_STEPS=300

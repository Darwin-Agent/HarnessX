# TB2 + meta-harness experiment environment — local Docker mode.
# Shared by run.py (meta-agent) and eval_local_docker.sh (TB2 eval).
#
# Copy to .env and fill in your values:
#   cp recipe/tb2_evolver/.env.example recipe/tb2_evolver/.env
#
# IMPORTANT: Use eval_local_docker.sh instead of eval_opensandbox.sh, e.g.:
#   python -m recipe.terminal_bench_2_with_metav2.run \
#     --tb2-eval-script benchmarks/terminal_bench_2/scripts/eval_local_docker.sh \
#     ...

# ── API credentials ───────────────────────────────────────────────────────────
ANTHROPIC_API_BASE=https://api.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Meta-agent model (runs evolution) ────────────────────────────────────────
META_MODEL=claude-opus-4-6
PROVIDER_ID=anthropic

# ── TB2 task-agent model (runs benchmark tasks) ───────────────────────────────
# Self-hosted SGLang endpoint serving Qwen3.5-27B (used in all evolution experiments)
TB2_MODEL=qwen3.5-27b             # or the model ID your SGLang instance exposes (e.g. /preset-models)
TB2_API_BASE=http://<sglang-host>:<port>/v1
TB2_API_KEY=none
# Fallback model ID (used if TB2_MODEL/TB2_API_BASE not set)
MODEL=qwen3.5-27b

# ── Local Docker proxy (omit or leave blank if not needed) ────────────────────
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost

# ── Evolution limits ──────────────────────────────────────────────────────────
EVOLVE_COST_CAP_USD=none          # e.g. 30.0 to cap meta-agent spend; "none" = unlimited
EVOLVE_MAX_STEPS=200              # max tool-use steps per meta-agent session
EVOLVE_EARLY_REMINDER_STEP=80     # step at which meta-agent receives an early progress reminder
EVOLVE_REMINDER_STEP=120          # step at which meta-agent receives a final reminder
EVOLVE_WALL_CLOCK_S=3600          # hard wall-clock limit per evolution round (seconds)

# ── TB2 eval settings ─────────────────────────────────────────────────────────
TB2_TASK_TIMEOUT=900              # per-task agent timeout (seconds)
CONCURRENT=8                      # number of tasks to run in parallel per eval round

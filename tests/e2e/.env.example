# E2E test model configuration — copy this file to tests/e2e/.env and fill in your credentials.
#
# Priority (highest to lowest):
#   1. ~/.harnessx/model_config.yaml  (written by /model default or hx lab)
#   2. ANTHROPIC_*  → AnthropicProvider
#   3. OPENAI_*     → LiteLLMProvider
#   4. LITELLM_*    → LiteLLMProvider
#   5. Fallback     → AnthropicProvider("claude-sonnet-4-6")

# ── Anthropic (native SDK) ────────────────────────────────────────────────────
# ANTHROPIC_API_BASE=https://api.anthropic.com          # optional: proxy base URL
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_DEFAULT_MAIN_MODEL=claude-sonnet-4-6

# ── OpenAI / OpenAI-compatible (via LiteLLM) ──────────────────────────────────
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_DEFAULT_MAIN_MODEL=gpt-4o

# ── LiteLLM generic (any provider LiteLLM supports) ──────────────────────────
# LITELLM_API_BASE=
# LITELLM_API_KEY=
# LITELLM_DEFAULT_MAIN_MODEL=

# ── Shared extras ─────────────────────────────────────────────────────────────
# EXTRA_HEADERS="X-Model-Provider-Id: xxx"          # JSON or KEY:VALUE,... format
# HARNESSX_REQUEST_TIMEOUT=120                       # seconds (default: 120)

# ── Test workspace ────────────────────────────────────────────────────────────
# HXE2E_TEST_HOME is the agent_home used by all e2e tests.
# Run trajectories, session journals, and config files are written here.
# This directory is NOT automatically cleaned up after tests — inspect the
# files for debugging, then remove manually when no longer needed.
HXE2E_TEST_HOME="/tmp/hx_test_e2e"
